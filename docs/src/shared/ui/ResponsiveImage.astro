---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import { LIGHTBOX_FULL_SRC_ATTR } from "@/shared/config/lightbox-dom";
import { getRootRelativeUrlForMetadata, resolveImageSource } from "@/shared/lib/media/image-assets";
import { withBase } from "@/shared/lib/routing/urls";

type ImageFormat = "avif" | "webp";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  /** When true, image is decorative (alt empty) - adds role="presentation" and aria-hidden for accessibility */
  decorative?: boolean;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  sizes?: string;
  width?: number;
  height?: number;
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  wrapperClass?: string;
  formats?: ImageFormat[];
  /** Absolute or site-prefixed URL to the original file for the image lightbox (skips responsive `currentSrc`). */
  lightboxFullSrc?: string;
}

const {
  src,
  alt = "",
  decorative = false,
  loading = "lazy",
  decoding = "async",
  sizes = "100vw",
  width,
  height,
  fetchpriority,
  class: className,
  wrapperClass,
  formats = ["avif", "webp"],
  lightboxFullSrc,
}: Props = Astro.props;

const resolvedSrc = resolveImageSource(src);

/** `src/assets/images` mirrored to `dist/assets/images` by `copy-src-images-to-dist`. Astro `Picture` omits `base` in `srcset` for these, which breaks GitHub Pages (`/Millennium-Dawn/`). */
function docsStaticImagesPath(resolved: string | ImageMetadata): string | undefined {
  if (typeof resolved === "string") {
    return resolved.startsWith("/assets/images/") ? resolved : undefined;
  }
  const url = getRootRelativeUrlForMetadata(resolved);
  return url?.startsWith("/assets/images/") ? url : undefined;
}

const staticDocsAssetPath = docsStaticImagesPath(resolvedSrc);
const staticDocsImgSrc = staticDocsAssetPath ? withBase(staticDocsAssetPath) : "";

/* Layout/centering for content images: `#main-content` in app.css */
const pictureClassName = [wrapperClass?.trim()].filter(Boolean).join(" ");
const imageClassName = className?.trim() ? className.trim() : "rounded";
const isStringSource = typeof resolvedSrc === "string";
const resolvedWidth = width ?? (isStringSource ? undefined : resolvedSrc.width);
const resolvedHeight = height ?? (isStringSource ? undefined : resolvedSrc.height);

if (!resolvedWidth || !resolvedHeight) {
  throw new Error("ResponsiveImage requires width and height for string sources.");
}

const resolvedAlt = decorative ? "" : alt;
const pictureAttrs = decorative ? { role: "presentation" as const, "aria-hidden": "true" as const } : {};
const pictureAttributes = {
  class: pictureClassName,
  ...pictureAttrs,
  ...(lightboxFullSrc ? { [LIGHTBOX_FULL_SRC_ATTR]: lightboxFullSrc } : {}),
};
---

{
  staticDocsAssetPath ? (
    <picture {...pictureAttributes}>
      <img
        src={staticDocsImgSrc}
        alt={resolvedAlt}
        width={resolvedWidth}
        height={resolvedHeight}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
        sizes={sizes}
        class={imageClassName}
      />
    </picture>
  ) : isStringSource ? (
    <Picture
      src={resolvedSrc}
      alt={resolvedAlt}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
      formats={formats}
      layout="constrained"
      class={imageClassName}
      pictureAttributes={pictureAttributes}
    />
  ) : (
    <Picture
      src={resolvedSrc}
      alt={resolvedAlt}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
      formats={formats}
      layout="constrained"
      class={imageClassName}
      pictureAttributes={pictureAttributes}
    />
  )
}
